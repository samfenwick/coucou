# Voxtral model (runs locally on Apple Silicon via mlx-audio)
LOCAL_MODEL=mlx-community/Voxtral-Mini-4B-Realtime-2602-4bit

# Translation
TRANSLATE=true
TARGET_LANGUAGE=en

# Diarization
DIARIZE=true

# Server
PORT=8000
HOST=0.0.0.0
ADMIN_PORT=8001
ADMIN_HOST=127.0.0.1    # set to 0.0.0.0 to expose on Tailnet

# Buffer tuning
BUFFER_SECONDS=30
CHUNK_SECONDS=8
OVERLAP_SECONDS=2
