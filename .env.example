# Whisper transcription endpoint (OpenAI-compatible)
WHISPER_ENDPOINT=http://localhost:8080/v1/audio/transcriptions
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_API_KEY=

# Server
PORT=8000
HOST=0.0.0.0
ADMIN_PORT=8001
ADMIN_HOST=127.0.0.1    # set to 0.0.0.0 to expose on Tailnet

# Buffer tuning
BUFFER_SECONDS=10
CHUNK_SECONDS=5
OVERLAP_SECONDS=2
